@startuml netflix-playback-components
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle uml2
skinparam shadowing false
skinparam DefaultFontName Manrope
skinparam DefaultFontSize 12
skinparam ArrowColor #475569
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #15803d
skinparam DatabaseBackgroundColor #f0fdf4
skinparam CloudBorderColor #7c3aed
skinparam CloudBackgroundColor #f5f3ff
skinparam PackageBorderColor #be185d
skinparam PackageBackgroundColor #fdf2f8

title Netflix Playback — Diagrama de Componentes

package "Cliente" {
  [Netflix App] as App
}

package "Backend (AWS us-east-1)" {
  [API Gateway · Zuul]        as GW
  [Playback Orchestrator]     as Orch
  [DRM Service]               as DRM
  [Catalog Service]           as Cat
  [User Profile Service]      as Prof
}

cloud "Externo · ISP" {
  [Open Connect (CDN)] as CDN
}

App  --( GW   : IHttp
GW   --( Orch : IPlayback
Orch --( DRM  : ILicense
Orch --( Cat  : ICatalog
Orch --( Prof : IProfile
App  --( CDN  : IStream

note right of CDN
  Stream HLS/DASH
  direto do ISP
  ~10ms de latência
end note

@enduml
