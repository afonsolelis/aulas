@startuml uml-components-notation
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle uml2
skinparam shadowing false
skinparam DefaultFontName Manrope
skinparam DefaultFontSize 13
skinparam ArrowColor #475569
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff

title Anatomia da notação UML de Componentes

component A as "Componente A\n(requer IService)"
component B as "Componente B\n(fornece IService\nrequer ILog e IDb)"
component C as "Componente C\n(fornece ILog)"
component D as "Componente D\n(fornece IDb)"

A --( B : IService
B --( C : ILog
B --( D : IDb

note bottom of A
  socket = requer
end note

note bottom of C
  lollipop = fornece
end note

@enduml
